FROM python:3.12-slim
WORKDIR /tests

# docker CLI lets chaos + log-scraping tests reach sibling containers via
# the host docker socket (mounted into the test-runner container).
RUN apt-get update \
    && apt-get install -y --no-install-recommends docker.io \
    && rm -rf /var/lib/apt/lists/*

COPY tests/ ./tests/
COPY scripts/ ./scripts/
RUN pip install --no-cache-dir requests pytest
ENTRYPOINT ["python", "-m", "pytest"]
CMD ["tests/", "-v", "--tb=short"]
